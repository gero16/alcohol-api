{
  "name": "alcohol-api",
  "version": "1.0.0",
  "description": "API REST para exponer y administrar información de alcoholes",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json --noEmit",
    "start": "tsx src/server.ts",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "backup:export": "tsx src/scripts/export-backup.ts",
    "backup:bootstrap": "tsx src/scripts/bootstrap-backup.ts",
    "glossary:import": "tsx src/scripts/import-glossary.ts",
    "content:sync": "npm run db:push && npm run db:seed"
  },
  "keywords": [
    "fastify",
    "prisma",
    "api",
    "alcoholes"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
