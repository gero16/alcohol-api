generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id            String                @id @default(cuid())
  slug          String                @unique
  position      Int
  title         String
  summary       String
  abv           String
  origin        String
  imageUrl      String
  imageAlt      String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  guide         Guide?
  glossaryLinks GlossaryItemCategory[]
}

model Guide {
  id         String    @id @default(cuid())
  categoryId String    @unique
  title      String
  type       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tabs       GuideTab[]
}

model GuideTab {
  id          String         @id @default(cuid())
  guideId      String
  slug         String
  label        String
  panelTitle   String?
  noteTitle    String?
  noteContent  String?
  position     Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  guide        Guide          @relation(fields: [guideId], references: [id], onDelete: Cascade)
  sections     GuideSection[]
  tables       GuideTable[]

  @@unique([guideId, slug])
  @@index([guideId, position])
}

model GuideSection {
  id         String           @id @default(cuid())
  tabId       String
  slug        String
  title       String
  subtitle    String
  imageUrl    String
  imageAlt    String
  position    Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tab         GuideTab         @relation(fields: [tabId], references: [id], onDelete: Cascade)
  paragraphs  GuideParagraph[]

  @@unique([tabId, slug])
  @@index([tabId, position])
}

model GuideParagraph {
  id        String       @id @default(cuid())
  sectionId String
  content   String
  position  Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  section   GuideSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, position])
}

model GuideTable {
  id        String         @id @default(cuid())
  tabId      String
  slug       String
  title      String
  columns    Json
  position   Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  tab        GuideTab       @relation(fields: [tabId], references: [id], onDelete: Cascade)
  rows       GuideTableRow[]

  @@unique([tabId, slug])
  @@index([tabId, position])
}

model GuideTableRow {
  id          String      @id @default(cuid())
  tableId      String
  term         String
  composition  String?
  objective    String?
  description  String?
  reference    String?
  abv          String?
  imageUrl     String?
  imageAlt     String?
  position     Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  table        GuideTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId, position])
}

model GlossaryItem {
  id                String                @id @default(cuid())
  slug              String                @unique
  term              String
  shortDefinition   String
  featured          Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  details           GlossaryDetail[]
  relatedCategories GlossaryItemCategory[]
}

model GlossaryDetail {
  id             String       @id @default(cuid())
  glossaryItemId String
  content        String
  position       Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  glossaryItem   GlossaryItem @relation(fields: [glossaryItemId], references: [id], onDelete: Cascade)

  @@index([glossaryItemId, position])
}

model GlossaryItemCategory {
  glossaryItemId String
  categoryId     String
  position       Int
  createdAt      DateTime     @default(now())
  glossaryItem   GlossaryItem @relation(fields: [glossaryItemId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([glossaryItemId, categoryId])
  @@index([categoryId, position])
  @@index([glossaryItemId, position])
}
